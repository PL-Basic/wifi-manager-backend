<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.plagod.mapper.Esp32NodeMapper">

    <select id="selectByDeviceCodeIncludeDeleted" resultType="com.plagod.entity.Esp32Node">
        select * from t_esp32_node where device_code = #{deviceCode} limit 1
    </select>

</mapper>
